# ═══════════════════════════════════════════
#  LearnFlow Environment Variables
#  Copy this file to .env and fill in values
# ═══════════════════════════════════════════

# ── Database ─────────────────────────────
# Local:  mongodb://localhost:27017/learnflow
# Docker: mongodb://mongo:27017/learnflow
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/learnflow
MONGODB_URI=mongodb://localhost:27017/learnflow

# ── Authentication ────────────────────────
# Generate a strong random string (min 32 chars)
JWT_SECRET=change-me-to-a-strong-random-secret

# ── Email (Gmail SMTP) ────────────────────
# Enable 2FA on your Gmail, then generate an App Password:
# https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Google Gemini AI ──────────────────────
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# ── Server ────────────────────────────────
PORT=5000
AI_SERVICE_URL=http://localhost:5001
AI_SERVICE_PORT=5001
